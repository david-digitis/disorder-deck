{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.digitis.disorder-deck",
  "Name": "Disorder Deck",
  "Author": "Digitis",
  "Description": "Control Disorder Overlay from your Stream Deck",
  "Version": "1.3.0.0",
  "CodePath": "bin/plugin.js",
  "Icon": "imgs/plugin-icon",
  "Category": "Disorder",
  "CategoryIcon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.9"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Actions": [
    {
      "UUID": "com.digitis.disorder-deck.toggle-admin-tab",
      "Name": "OP / ALL",
      "Tooltip": "Bascule entre les onglets OP et ALL du panneau admin",
      "Icon": "imgs/actions/toggle-admin",
      "States": [
        {
          "Image": "imgs/actions/toggle-admin"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.toggle-fleet",
      "Name": "Fleet",
      "Tooltip": "Afficher / masquer le panneau Fleet",
      "Icon": "imgs/actions/toggle-fleet",
      "States": [
        {
          "Image": "imgs/actions/toggle-fleet"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.toggle-ts-live",
      "Name": "TS Live",
      "Tooltip": "Afficher / masquer le panneau TS Live",
      "Icon": "imgs/actions/toggle-fleet",
      "States": [
        {
          "Image": "imgs/actions/toggle-fleet"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.trigger-help",
      "Name": "Help (SOS)",
      "Tooltip": "Envoie un signal Help visible par tous",
      "Icon": "imgs/actions/help",
      "States": [
        {
          "Image": "imgs/actions/help"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.trigger-dead",
      "Name": "Status",
      "Tooltip": "Cycle de statut : RDY / DEAD / WAIT",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.check-raid",
      "Name": "Check Raid",
      "Tooltip": "Lancer un check raid",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.raid-off",
      "Name": "Raid Off",
      "Tooltip": "Fin du raid",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.rally",
      "Name": "Rassemblement",
      "Tooltip": "Appel au rassemblement",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.reset-status",
      "Name": "Reset Status",
      "Tooltip": "Reset tous les statuts",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.screenshot",
      "Name": "Screenshot",
      "Tooltip": "Prendre un screenshot et poster sur Discord",
      "Icon": "imgs/actions/screenshot",
      "States": [
        {
          "Image": "imgs/actions/screenshot"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.toggle-clip",
      "Name": "Clip Discord",
      "Tooltip": "Enregistrer un clip et poster sur Discord",
      "Icon": "imgs/actions/clip-off",
      "States": [
        {
          "Image": "imgs/actions/clip-off"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.toggle-auto-ping",
      "Name": "Auto-Ping",
      "Tooltip": "Activer / desactiver l'auto-ping Tab",
      "Icon": "imgs/actions/ping-off",
      "States": [
        {
          "Image": "imgs/actions/ping-off"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.toggle-overlay",
      "Name": "Show / Hide",
      "Tooltip": "Afficher / masquer l'overlay",
      "Icon": "imgs/actions/toggle-admin",
      "States": [
        {
          "Image": "imgs/actions/toggle-admin"
        }
      ]
    },
    {
      "UUID": "com.digitis.disorder-deck.studio-record",
      "Name": "Record",
      "Tooltip": "Demarrer / arreter l'enregistrement Studio",
      "Icon": "imgs/actions/dead",
      "States": [{ "Image": "imgs/actions/dead" }]
    },
    {
      "UUID": "com.digitis.disorder-deck.studio-buffer",
      "Name": "Tampon",
      "Tooltip": "Activer / desactiver le tampon de relecture",
      "Icon": "imgs/actions/dead",
      "States": [{ "Image": "imgs/actions/dead" }]
    },
    {
      "UUID": "com.digitis.disorder-deck.studio-replay",
      "Name": "Sauver Replay",
      "Tooltip": "Sauvegarder le replay du tampon",
      "Icon": "imgs/actions/dead",
      "States": [{ "Image": "imgs/actions/dead" }]
    },
    {
      "UUID": "com.digitis.disorder-deck.quit-overlay",
      "Name": "Quit Overlay",
      "Tooltip": "Fermer Disorder Overlay",
      "Icon": "imgs/actions/dead",
      "States": [
        {
          "Image": "imgs/actions/dead"
        }
      ]
    }
  ]
}